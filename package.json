{
  "name": "se-harness",
  "version": "0.2.0",
  "description": "Portable, tool-agnostic AI coding harness generator. One source of truth via AGENTS.md \u2014 a unified global ruleset plus per-project, technology-aware guideline modules.",
  "type": "module",
  "bin": { "seh": "dist/cli.js" },
  "files": ["dist", "assets"],
  "license": "MIT",
  "author": "manuuuel",
  "repository": { "type": "git", "url": "git+https://github.com/manuuuel/seh.git" },
  "homepage": "https://github.com/manuuuel/seh#readme",
  "bugs": { "url": "https://github.com/manuuuel/seh/issues" },
  "keywords": ["ai", "agents-md", "coding-agents", "claude-code", "codex", "cursor", "cli", "developer-tools", "llm", "code-quality"],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "try": "bash scripts/try.sh"
  },
  "engines": { "node": ">=18" },
  "dependencies": { "commander": "^12.0.0", "prompts": "^2.4.2" },
  "devDependencies": {
    "@types/node": "^20.0.0", "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0", "tsx": "^4.0.0", "typescript": "^5.4.0", "vitest": "^1.4.0"
  }
}
